---
const corporate = [
	{ label: 'Portfolio',  href: '#portfolio'  },
	{ label: 'Strategy',   href: '#hero'   },
	{ label: 'Insights',       href: '#counter-section-blue'   },
]

const contact = {
	address: '101 Brickell Ave, Miami, FL',
	email:   'invest@harborcap.com',
	phone:   '+1 (305) 555-0126',
}

const legal = [
	{ label: 'Privacy Policy',  href: '#' },
	{ label: 'Terms of Service', href: '#' },
	{ label: 'SEC Disclosures', href: '#' },
	{ label: 'Investor Portal', href: '#' },
]

const legalMobile = [
	{ label: 'Terms of Service', href: '#' },
	{ label: 'Privacy Policy',   href: '#' },
	{ label: 'Investor Portal',  href: '#' },
]
---

<footer id='contact' class='bg-white border-t border-border'>

	<!-- ── DESKTOP / TABLET ── -->
	<div class='hidden md:block px-[5vw] pt-14 pb-8'>
		<div class='grid grid-cols-4 gap-10 mb-12'>

			<!-- Col 1: brand + description -->
			<div class='col-span-1'>
				<a href='/' class='font-body font-bold text-[13px] uppercase tracking-[0.14em] text-[#0F172A] block mb-4'>
					Harbor Capital Partners
				</a>
				<p class='font-body text-[13px] text-[#64748B] leading-relaxed'>
					Lorem ipsum dolor sit amet consectetur adipiscing elit sociis viverra, volutpat ornare ridiculus magna.
				</p>
			</div>

			<!-- Col 2: Corporate -->
			<div>
				<h6 class='font-display font-bold text-[10px] md:text-[13px] uppercase tracking-[0.14em] text-[#0F172A] mb-5'>
					Corporate
				</h6>
				<ul class='space-y-3'>
					{corporate.map(link => (
						<li>
							<a href={link.href} class='font-body text-[13px] text-[#64748B] hover:text-[#B59A5D] transition-colors duration-200'>
								{link.label}
							</a>
						</li>
					))}
				</ul>
			</div>

			<!-- Col 3: Contact -->
			<div>
				<h6 class='font-display font-bold text-[10px] md:text-[13px] uppercase tracking-[0.14em] text-[#0F172A] mb-5'>
					Contact
				</h6>
				<ul class='space-y-3'>
					<li class='font-body text-[13px] text-[#64748B]'>{contact.address}</li>
					<li>
						<a href={`mailto:${contact.email}`} class='font-body text-[13px] text-[#64748B] hover:text-[#B59A5D] transition-colors duration-200'>
							{contact.email}
						</a>
					</li>
					<li>
						<a href={`tel:${contact.phone}`} class='font-body text-[13px] text-[#64748B] hover:text-[#B59A5D] transition-colors duration-200'>
							{contact.phone}
						</a>
					</li>
				</ul>
			</div>

			<!-- Col 4: Access -->
			<div>
				<h6 class='font-display font-bold text-[10px] md:text-[13px] uppercase tracking-[0.14em] text-[#0F172A] mb-5'>
					Access
				</h6>
				<a
					href='#'
					class='inline-block font-body font-bold text-[11px] uppercase tracking-[0.1em]
					       bg-[#0F172A] text-white px-5 py-3
					       hover:bg-[#B59A5D] transition-colors duration-300'
				>
					Investor Portal Login
				</a>
			</div>
		</div>

		<!-- Bottom bar -->
		<div class='border-t border-border pt-6 flex items-center justify-between'>
			<p class='font-body text-[12px] text-[#94A3B8]'>
				© 2024 Harbor Capital Partners. Institutional Quality Real Estate Investment.
			</p>
			<div class='flex items-center gap-6'>
				{legal.map(link => (
					<a href={link.href} class='font-body text-[12px] text-[#94A3B8] hover:text-[#B59A5D] transition-colors duration-200'>
						{link.label}
					</a>
				))}
			</div>
		</div>
	</div>

	<!-- ── MOBILE ── -->
	<div class='md:hidden px-[5vw] pt-10 pb-8'>

		<!-- Brand -->
		<a href='/' class='font-display font-bold text-[14px] uppercase tracking-[0.12em] text-[#0F172A] block mb-6'>
			Harbor Capital Partners
		</a>

		<!-- Legal links stacked -->
		<ul class='space-y-4 mb-8'>
			{legalMobile.map(link => (
				<li>
					<a href={link.href} class='font-body text-[14px] text-[#64748B] hover:text-[#B59A5D] transition-colors duration-200'>
						{link.label}
					</a>
				</li>
			))}
		</ul>

		<!-- Bottom -->
		<div class='border-t border-border pt-6'>
			<p class='font-body text-[12px] text-[#94A3B8]'>
				© 2024 Harbor Capital Partners. Institutional Quality.
			</p>
		</div>
	</div>

</footer>
---
const leader = {
	name: 'Marcus Thorne',
	role: 'Managing Partner & Founder',
	avatar: '/img/marcus.jpg',
	quote:
		'"Lorem ipsum dolor sit amet consectetur adipiscing elit sociis viverra, volutpat ornare ridiculus magna nulla inceptos egestas scelerisque mus habitant."',
}

const investorCard = {
	icon: '⌂',
	text: 'Lorem ipsum dolor sit amet consectetur adipiscing elit sociis viverra.',
}
---

<section id='leadership' class='bg-white py-20 md:py-24 lg:py-28 overflow-hidden'>
	<div class='px-[5vw] mx-auto'>

		<!-- ── DESKTOP / TABLET ── -->
		<div class='hidden md:grid md:grid-cols-2 gap-12 lg:gap-16 items-center'>

			<!-- Left: text content -->
			<div data-aos='fade-right' data-aos-duration='800'>
				<p class='font-body font-semibold text-[10px] uppercase tracking-[0.14em] text-[#B59A5D] mb-4'>
					Firm Overview
				</p>

				<h2 class='font-display font-semibold text-[2rem] lg:text-[2.75rem] xl:text-[3rem] text-[#0F172A] leading-[1.1em] mb-6'>
					Boutique Expertise.<br />Institutional Scale.
				</h2>

				<div class='space-y-4 mb-10'>
					<p class='font-body text-[14px] lg:text-[15px] text-[#64748B] leading-relaxed'>
						Lorem ipsum dolor sit amet consectetur adipiscing elit sociis viverra, volutpat ornare ridiculus magna nulla inceptos egestas scelerisque mus habitant, accumsan ac parturient euismod sollicitudin eget arcu nostra.
					</p>
					<p class='font-body text-[14px] lg:text-[15px] text-[#64748B] leading-relaxed'>
						Metus urna a proin morbi sapien augue praesent leo, orci congue eros vulputate ultrices himenaeos neque, luctus vel conubia etiam habitasse vestibulum tristique. Tellus accumsan id semper scelerisque turpis euismod, enim elementum ad cubilia orci.
					</p>
				</div>

				<!-- Leader -->
				<div class='flex items-center gap-4'>
					<img
						src={leader.avatar}
						alt={leader.name}
						class='w-12 h-12 rounded-full object-cover grayscale'
					/>
					<div>
						<p class='font-display font-semibold text-[15px] text-[#0F172A]'>{leader.name}</p>
						<p class='font-body text-[10px] uppercase tracking-[0.12em] text-[#B59A5D]'>{leader.role}</p>
					</div>
				</div>
			</div>

			<!-- Right: image + floating investor card -->
			<div class='relative' data-aos='fade-left' data-aos-duration='800' data-aos-delay='100'>
				<div class='overflow-hidden'>
					<img
						src='/img/about.jpg'
						alt='Harbor Capital office'
						class='w-full h-[420px] lg:h-[500px] object-cover'
					/>
				</div>

				<!-- Floating card -->
				<div
					class='absolute bottom-6 left-6 bg-[#0F172A] text-white p-5 max-w-[200px] lg:max-w-[220px]'
					data-aos='fade-up'
					data-aos-delay='300'
					data-aos-duration='700'
				>
					<p class='font-body text-[22px] mb-3 text-[#B59A5D]'>⌂</p>
					<p class='font-body text-[13px] leading-relaxed text-[#94A3B8]'>
						{investorCard.text}
					</p>
				</div>
			</div>
		</div>

		<!-- ── MOBILE ── -->
		<div class='flex flex-col gap-8 md:hidden'>

			<!-- Header -->
			<div data-aos='fade-up'>
				<h2 class='font-display font-semibold text-[1.75rem] text-[#0F172A] leading-[1.15em] mb-4'>
					Boutique Expertise.<br />Institutional Scale.
				</h2>
				<p class='font-body text-[14px] text-[#64748B] leading-relaxed'>
					Metus urna a proin morbi sapien augue praesent leo, orci congue eros vulputate ultrices himenaeos neque, luctus vel conubia etiam habitasse vestibulum tristique.
				</p>
			</div>

			<!-- Leader -->
			<div
				class='flex items-center gap-4 border-t border-b border-[#E2E8F0] py-6'
				data-aos='fade-up'
				data-aos-delay='80'
			>
				<img
					src={leader.avatar}
					alt={leader.name}
					class='w-12 h-12 rounded-full object-cover grayscale shrink-0'
				/>
				<div>
					<p class='font-display font-semibold text-[15px] text-[#0F172A]'>{leader.name}</p>
					<p class='font-body text-[10px] uppercase tracking-[0.12em] text-[#B59A5D]'>{leader.role}</p>
				</div>
			</div>

			<!-- Quote -->
			<div data-aos='fade-up' data-aos-delay='120'>
				<blockquote class='font-display text-[15px] text-[#0F172A] leading-relaxed italic border-l-2 border-[#B59A5D] pl-5'>
					{leader.quote}
				</blockquote>
			</div>

			<!-- Investor Portal card -->
			<div
				class='border border-[#E2E8F0] p-6'
				data-aos='fade-up'
				data-aos-delay='160'
			>
				<p class='font-body text-[20px] text-[#B59A5D] mb-3'>⌂</p>
				<p class='font-body font-semibold text-[13px] text-[#0F172A] uppercase tracking-[0.1em] mb-2'>
					Secure Investor Portal
				</p>
				<p class='font-body text-[13px] text-[#64748B] leading-relaxed mb-5'>
					Lorem ipsum dolor sit amet consectetur adipiscing elit sociis viverra.
				</p>
				<a
					href='#contact'
					class='block w-full text-center font-body font-semibold text-[12px] uppercase tracking-[0.12em]
					       border border-[#0F172A] text-[#0F172A] py-4
					       hover:bg-[#0F172A] hover:text-white transition-colors duration-300'
				>
					Investor Login
				</a>
			</div>
		</div>

	</div>
</section>

<script>
	import { gsap } from 'gsap'
	import { ScrollTrigger } from 'gsap/ScrollTrigger'

	gsap.registerPlugin(ScrollTrigger)

	gsap.from('#leadership h2', {
		opacity: 0,
		y: 30,
		duration: 0.9,
		ease: 'power3.out',
		scrollTrigger: {
			trigger: '#leadership',
			start: 'top 80%',
			toggleActions: 'play none none none',
		},
	})

	gsap.from('#leadership img.rounded-full', {
		opacity: 0,
		scale: 0.85,
		duration: 0.7,
		ease: 'back.out(1.4)',
		scrollTrigger: {
			trigger: '#leadership',
			start: 'top 75%',
			toggleActions: 'play none none none',
		},
		delay: 0.3,
	})
</script>
---
import defaultCounters from '../../data/countersSingleServices.json'

interface CounterItem {
	numericValue?: number
	staticValue?: string
	prefix?: string
	suffix?: string
	label?: string
	title: string
}

interface LocaleContent {
	counters: CounterItem[]
}

interface Props {
	data?: LocaleContent
}

const { data } = Astro.props
const content = data ?? defaultCounters
---

<section
	id='counter-section-blue'
	class='py-14 md:py-16 lg:py-20 bg-white border-b border-border overflow-x-hidden'
>
	<div class='w-full mx-auto px-[5vw]'>

		<div class='grid grid-cols-2 lg:grid-cols-4 gap-x-6 gap-y-8 md:gap-y-0 md:gap-x-0'>
			{content.counters.map((item) => (
				<div class='counter-item
					flex flex-col gap-1
					border-l-2 border-[#B59A5D] pl-4
					md:border-l-0 md:pl-0 md:border-t-0
					lg:border-l lg:border-border lg:pl-8 first:lg:border-l-0 first:lg:pl-0'
				>

					<span class='hidden md:block font-body  text-[10px] uppercase tracking-[0.12em] text-primary font-semibold mb-1'>
						{item.label}
					</span>

					<span class='font-display font-semibold leading-none text-[#0F172A]
					            text-[1.6rem] md:text-[2.25rem] lg:text-[2.5rem] xl:text-[2.75rem]'>
						{item.staticValue ? (
							item.staticValue
						) : (
							<>
								{item.prefix}<span
									class='counter'
									data-target={item.numericValue}
									data-prefix={item.prefix ?? ''}
									data-suffix={item.suffix ?? ''}
								>0</span>{item.suffix}
							</>
						)}
					</span>

					<span class='font-body text-[11px] md:text-[13px] text-primary font-semibold  tracking-[0.06em] leading-snug'>
						{item.title}
					</span>

				</div>
			))}
		</div>

	</div>
</section>

<script>
	import { gsap } from 'gsap'
	import { ScrollTrigger } from 'gsap/ScrollTrigger'

	gsap.registerPlugin(ScrollTrigger)

	const counters = document.querySelectorAll<HTMLElement>('.counter')

	counters.forEach((counter) => {
		const target = parseFloat(counter.getAttribute('data-target') ?? '0')
		if (isNaN(target)) return

		const obj = { val: 0 }

		gsap.to(obj, {
			val: target,
			duration: 2.5,
			ease: 'power2.out',
			snap: { val: 1 },
			scrollTrigger: {
				trigger: '#counter-section-blue',
				start: 'top 85%',
				toggleActions: 'play none none none',
			},
			onUpdate() {
				const formatted = Math.round(obj.val).toLocaleString('en-US')
				counter.textContent = formatted
			},
		})
	})

	gsap.from('.counter-item', {
		opacity: 0,
		y: 24,
		duration: 0.7,
		stagger: 0.12,
		ease: 'power2.out',
		scrollTrigger: {
			trigger: '#counter-section-blue',
			start: 'top 85%',
			toggleActions: 'play none none none',
		},
	})
</script>
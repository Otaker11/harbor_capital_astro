---
import { Image } from 'astro:assets';

import img1 from '../../assets/img/portfolio/portfolio1.webp';
import img2 from '../../assets/img/portfolio/portfolio2.webp';
import img3 from '../../assets/img/portfolio/portfolio3.webp';

const properties = [
	{
		id: 1,
		category: 'Multifamily',
		name: 'The Azure, Miami',
		location: 'Class-A Multifamily | Wynwood District',
		badge: 'ACQUIRED 2022',
		stat: '98% OCCUPANCY',
		img: img1,
		link: '#contact',
		size: 'large',
	},
	{
		id: 2,
		category: 'Class A Residential',
		name: 'Oaks at Buckhead, Atlanta',
		location: 'Garden-Style Value Add',
		badge: null,
		stat: 'STABILIZED',
		img: img2,
		link: '#contact',
		size: 'small',
	},
	{
		id: 3,
		category: 'Mixed Use',
		name: 'Harbor Heights, Charlotte',
		location: null,
		badge: 'CORE-PLUS ASSET',
		stat: null,
		desc: 'A vertically integrated mixed-use development anchored by institutional-grade multifamily units in the heart of Charlotte\'s growth corridor.',
		units: '482',
		occupancy: '96.4%',
		img: img3,
		link: '#contact',
		size: 'featured',
	},
]

---

<section id='portfolio' class='py-20 md:py-24 lg:py-28 bg-[#F8FAFC] h-full'>
	<div class='px-[5vw] mx-auto'>

		<div class='mb-12 md:mb-16' data-aos='fade-up'>
			<p class='font-body font-bold text-[12px] md:text-[16px] uppercase tracking-[0.14em] text-primary mb-3'>
				Investment Portfolio
			</p>
			<h2 class='font-display font-semibold text-[1.75rem] md:text-[2.25rem] lg:text-[2.75rem] text-[#0F172A] leading-tight'>
				Strategic Asset Holdings
			</h2>
			<div class='w-10 h-0.5 bg-[#B59A5D] mt-4'></div>
		</div>

		<!-- ── DESKTOP / TABLET GRID ── -->
		<div class='hidden md:block'>

			<!-- Row 1: large card + small card -->
			<div class='grid grid-cols-3 gap-4 mb-4'>

				<!-- Large card (col-span-2) -->
				<div
					class='col-span-2 group bg-white overflow-hidden '
					data-aos='fade-up'
					data-aos-delay='0'
				>
					<div class='overflow-hidden h-56 lg:h-102'>
						<Image
							src={properties[0].img}
							alt={properties[0].name}
							widths={[768, 1280, 1920]}
							sizes="(max-width: 1024px) 100vw, 66vw"
							quality={70}
							format="webp"
							class='w-full h-full object-cover transition-transform duration-700 group-hover:scale-105'
						/>
					</div>
					<div class='p-5 flex items-start justify-between gap-4 border border-t-0 border-border'>
						<div>
							<p class='font-display font-semibold text-[1.1rem] lg:text-[1.25rem] text-[#0F172A] mb-1'>
								{properties[0].name}
							</p>
							<p class='font-body text-[12px] text-primary font-semibold'>
								{properties[0].location}
							</p>
						</div>
						<div class='flex items-center gap-3 shrink-0'>
							{properties[0].badge && (
								<span class='mt-5 font-body text-[10px] md:text-[15px] uppercase tracking-[0.1em] text-primary whitespace-nowrap font-semibold'>
									{properties[0].badge}
								</span>
							)}
							
						</div>
					</div>
				</div>

				<!-- Small card (col-span-1) -->
				<div
					class='col-span-1 group bg-white overflow-hidden '
					data-aos='fade-up'
					data-aos-delay='100'
				>
					<div class='overflow-hidden h-56 lg:h-102'>
						<Image
							src={properties[1].img}
							alt={properties[1].name}
							widths={[768, 1280, 1920]}
							sizes="(max-width: 1024px) 100vw, 66vw"
							quality={70}
							format="webp"
							class='w-full h-full object-cover transition-transform duration-700 group-hover:scale-105'
						/>
					</div>
					<div class='p-5 border border-t-0 border-border'>
						<p class='font-display font-semibold text-[1.1rem] lg:text-[1.25rem] text-[#0F172A] mb-1'>
							{properties[1].name}
						</p>
						<p class='font-body text-[12px] text-primary font-semibold'>
							{properties[1].location}
						</p>
					</div>
				</div>
			</div>

			<!-- Row 2: featured card (image left + content right) -->
			<div
				class='grid grid-cols-7 bg-white border border-border overflow-hidden'
				data-aos='fade-up'
				data-aos-delay='150'
			>
				<div class='col-span-4 overflow-hidden lg:h-102'>
					<Image
							src={properties[2].img}
							alt={properties[2].name}
							widths={[768, 1280, 1920]}
							sizes="(max-width: 1024px) 100vw, 66vw"
							quality={70}
							format="webp"
						class='w-full h-full object-cover transition-transform duration-700 group-hover:scale-105'
					/>
				</div>
				<div class='col-span-3 p-8 lg:p-10 flex flex-col justify-center'>
					{properties[2].badge && (
						<p class='font-body font-semibold text-[10px] uppercase tracking-[0.14em] text-primary mb-3'>
							{properties[2].badge}
						</p>
					)}
					<h3 class='font-display font-semibold text-[1.5rem] lg:text-[2rem] text-[#0F172A] leading-tight mb-4'>
						{properties[2].name}
					</h3>
					<p class='font-body text-[14px] text-[#64748B] leading-relaxed mb-8 max-w-lg'>
						{properties[2].desc}
					</p>
					<div class='flex gap-10'>
						<div>
							<p class='font-display font-semibold text-[1.25rem] text-[#0F172A]'>{properties[2].units}</p>
							<p class='font-body text-[11px] uppercase tracking-[0.1em] text-primary font-semibold mt-1'>Total Units</p>
						</div>
						<div>
							<p class='font-display font-semibold text-[1.25rem] text-[#0F172A]'>{properties[2].occupancy}</p>
							<p class='font-body text-[11px] uppercase tracking-[0.1em] text-primary font-semibold mt-1'>Occupancy</p>
						</div>
					</div>
				</div>
			</div>
		</div>

		<!-- ── MOBILE: stacked cards ── -->
		<div class='flex flex-col gap-5 md:hidden'>
			{properties.map((prop, i) => (
				<div
					class='mobile-card bg-white overflow-hidden border border-border'
					data-aos='fade-up'
					data-aos-delay={i * 80}
				>
					<div class='overflow-hidden h-52 relative'>
						<Image
							src={prop.img}
							alt={prop.name}
							widths={[400, 768]}
							sizes="100vw"
							quality={70}
							loading="lazy"
							decoding="async"
							class='w-full h-full object-cover'
						/>
					</div>

					<div class='p-5'>
						<p class='font-body font-semibold text-[11px] uppercase tracking-[0.12em] text-primary mb-2'>
							{prop.category}
						</p>
						<p class='font-display font-semibold text-[1.1rem] text-[#0F172A] mb-4 leading-snug'>
							{prop.name}
						</p>
						{prop.desc && (
							<p class='font-body text-[13px] text-[#64748B] leading-relaxed mb-4'>
								{prop.desc}
							</p>
						)}
						<div class='flex items-center justify-between border-t border-border pt-4'>
							<span class='font-body font-medium text-[11px] uppercase tracking-[0.1em] text-[#64748B]'>
								{prop.stat ?? (prop.units ? `${prop.units} Units · ${prop.occupancy} Occ.` : '')}
							</span>
							<a href={prop.link} class='text-[#0F172A] hover:text-primary transition-colors'>
								<svg width='18' height='18' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='1.5'>
									<line x1='5' y1='12' x2='19' y2='12'/><polyline points='12 5 19 12 12 19'/>
								</svg>
							</a>
						</div>
					</div>
				</div>
			))}
		</div>

	</div>
</section>

<script>
	import { gsap } from 'gsap'
	import { ScrollTrigger } from 'gsap/ScrollTrigger'

	gsap.registerPlugin(ScrollTrigger)

	gsap.utils.toArray<HTMLElement>('.mobile-card').forEach((card, i) => {
		gsap.from(card, {
			opacity: 0,
			y: 32,
			duration: 0.65,
			ease: 'power2.out',
			scrollTrigger: {
				trigger: card,
				start: 'top 88%',
				toggleActions: 'play none none none',
			},
			delay: i * 0.08,
		})
	})
</script>